<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a2e"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SMS API Server"
            android:textColor="#e94560"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="16dp" />

        <!-- Status Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Status: STOPPED"
                android:textColor="#ff4444"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvIpAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="IP: ..."
                android:textColor="#4ecca3"
                android:textSize="14sp"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tvPort"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Port: 8080"
                android:textColor="#4ecca3"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="URL: http://..."
                android:textColor="#eee"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sent: 0 | Failed: 0 | Pending: 0"
                android:textColor="#aaa"
                android:textSize="13sp"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Server Control -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <EditText
                android:id="@+id/etPort"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="Port"
                android:text="8080"
                android:textColor="#eee"
                android:textColorHint="#666"
                android:background="@drawable/input_bg"
                android:inputType="number"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStart"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Start"
                android:backgroundTint="#4ecca3"
                android:textColor="#000"
                android:layout_marginEnd="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStop"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Stop"
                android:backgroundTint="#e94560"
                android:textColor="#fff" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRefresh"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="Refresh Status"
            android:backgroundTint="#0f3460"
            android:textColor="#4ecca3"
            android:layout_marginBottom="12dp" />

        <!-- Test Send -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Test Send SMS"
                android:textColor="#e94560"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etTestPhone"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:hint="Phone number (e.g. 905441497005)"
                android:textColor="#eee"
                android:textColorHint="#666"
                android:background="@drawable/input_bg"
                android:inputType="phone"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etTestMessage"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:hint="Message"
                android:textColor="#eee"
                android:textColorHint="#666"
                android:background="@drawable/input_bg"
                android:inputType="text"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTestSend"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Send Test SMS"
                android:backgroundTint="#e94560"
                android:textColor="#fff" />
        </LinearLayout>

        <!-- Logs -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Recent Logs"
                android:textColor="#e94560"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvLogs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No logs yet"
                android:textColor="#aaa"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:maxLines="15"
                android:scrollbars="vertical" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
